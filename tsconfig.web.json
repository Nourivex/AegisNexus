{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "skipLibCheck": true,
        "outDir": "public",
        "rootDir": "frontend"
    },
    "include": [
        "frontend/**/*.ts"
    ]
}
