{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node"
        ],
        "noEmit": true
    },
    "include": [
        "aegis.ts",
        "index.ts",
        "workspace.ts",
        "server.ts",
        "database.ts"
    ]
}
